NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required for the Stripe webhook + checkout-success handlers.
# These run server-side and need to bypass RLS to insert entitlement rows
# without the buyer having admin role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (test-mode keys for local development; live keys for production).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Single flat-rate Stripe Price ID used for every Unit purchase (€3.00 EUR, one-time).
# Test-mode value as of 2026-05-12: price_1TWLu0CbBje0sCsEadcen6py
STRIPE_UNIT_PRICE_ID=price_xxx

# Public site origin used for Stripe Checkout success/cancel URLs.
# Local dev: http://localhost:3000 — production: https://your-domain.tld
NEXT_PUBLIC_SITE_URL=http://localhost:3000
